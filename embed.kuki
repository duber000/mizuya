# mizuya — embedding provider abstraction.
#
# Thin wrapper over stdlib/llm/embeddings. Supports any OpenAI-compatible
# /v1/embeddings endpoint (OpenAI, Ollama, Voyage, Cohere, Mistral, …) plus
# a deterministic hash fallback when no provider is configured.
#
# Environment variables:
#   MIZUYA_EMBED_PROVIDER  — "openai", "ollama", "voyage", "cohere", …
#                            (default: "" = hash fallback)
#   MIZUYA_EMBED_URL       — base URL override (default: provider default)
#   MIZUYA_EMBED_MODEL     — model name (default: provider-appropriate)
#   MIZUYA_EMBED_API_KEY   — API key (optional for ollama)

petiole main

import "stdlib/env"
import "stdlib/llm/embeddings"

# embedConfig is the resolved embedding configuration. Empty provider means
# fall back to hashEmbed and the package-level EmbedDim/EmbedModel constants.
type embedConfig
    provider string
    url      string
    model    string
    apiKey   string

# loadEmbedConfig reads embedding settings from environment variables and
# applies provider-specific defaults.
func loadEmbedConfig() embedConfig
    provider := env.GetOr("MIZUYA_EMBED_PROVIDER", "")
    url := env.GetOr("MIZUYA_EMBED_URL", "")
    model := env.GetOr("MIZUYA_EMBED_MODEL", "")
    apiKey := env.GetOr("MIZUYA_EMBED_API_KEY", "")

    if provider equals "ollama" and model equals ""
        model = "nomic-embed-text"
    if provider equals "openai" and model equals ""
        model = "text-embedding-3-small"
    return embedConfig{provider: provider, url: url, model: model, apiKey: apiKey}

# embedText converts text into a vector using the configured provider.
# Falls back to hashEmbed when no provider is set.
func embedText(text: string) (list of float64, error)
    cfg := loadEmbedConfig()
    if cfg.provider equals ""
        return hashEmbed(text, EmbedDim), empty
    client := embeddings.New(cfg.model) |> embeddings.Provider(cfg.provider)
    if cfg.url isnt ""
        client = embeddings.BaseURL(client, cfg.url)
    if cfg.apiKey isnt ""
        client = embeddings.APIKey(client, cfg.apiKey)
    vec32 := embeddings.EmbedOne(client, text) onerr return
    out := make(list of float64, len(vec32))
    for i, v in vec32
        out[i] = v as float64
    return out, empty

# embedModel returns the model identifier for the current provider,
# used when storing the model tag alongside the embedding.
func embedModel() string
    cfg := loadEmbedConfig()
    if cfg.provider equals ""
        return EmbedModel
    return cfg.model
