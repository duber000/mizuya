# mizuya — model types
# A SQLite-backed knowledge graph with JSON columns, FTS5 keyword search,
# 1-hop context lookups, and vector cosine similarity (via a registered
# custom SQL function).

petiole main

# Entity is a node in the knowledge graph.
# The Data field holds a JSON object: {summary, observations, tags}.
type Entity
    Id string as "id"
    Type string as "type"
    Name string as "name"
    Data string as "data"
    CreatedAt string as "created_at"
    UpdatedAt string as "updated_at"

# Relation is a typed edge between two entities.
type Relation
    Src string as "src"
    Rel string as "rel"
    Dst string as "dst"
    Data string as "data"
    CreatedAt string as "created_at"

# SearchHit is a single row from an FTS5 search.
type SearchHit
    Id string as "id"
    Type string as "type"
    Name string as "name"
    Summary string as "summary"

# ContextRow describes one end of a 1-hop neighbor edge.
type ContextRow
    Rel string as "rel"
    Other string as "other"
    Name string as "name"
    Type string as "type"
    Summary string as "summary"

# ReachableRow describes an entity reached via N-hop graph traversal
# through the closure virtual table. Depth is the minimum hop count
# from the root; the relation label isn't carried (closure walks any
# edge regardless of `rel`).
type ReachableRow
    Depth int as "depth"
    Other string as "other"
    Name string as "name"
    Type string as "type"
    Summary string as "summary"

# ObsRow is a single observation row from the observations table.
# Id is a uuid7 string assigned by SQLite at INSERT time.
type ObsRow
    Id string as "id"
    Text string as "text"
    Source string as "source"
    At string as "at"

# SimilarHit is a single row from a vector similarity search.
type SimilarHit
    Id string as "id"
    Name string as "name"
    Type string as "type"
    Summary string as "summary"
    Distance float64 as "distance"

# hashRow scans the content_hash column for change detection.
type hashRow
    Hash string as "hash"

# suggestRow is a single fuzzy-match suggestion from the spellfix1
# vtab. Word is the matched id; we don't currently surface rank or
# distance.
type suggestRow
    Word string as "word"

# entityData is the typed view of the JSON stored in the entities.data
# column. Unknown fields (like observations) are ignored on unmarshal.
type entityData
    Summary string as "summary"
    Tags list of string as "tags"

# vecRow scans a stored float32 LE BLOB from the vec_raw side-copy
# column. We carry the BLOB as metadata in the vec1 table because
# vec1's indexed `vector` column reads back in an opaque native
# layout outside the KNN path.
type vecRow
    Vec list of byte as "vec"

# EmbedDim is the dimensionality of the fallback hash embedding.
# Real providers (ollama, openai) determine dim from the model output.
const EmbedDim int = 64

# EmbedModel is the fallback model tag when no provider is configured.
const EmbedModel string = "hash-demo-64"
