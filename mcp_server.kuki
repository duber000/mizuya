# mizuya — MCP stdio server
# Registers 6 tools so AI agents (Claude Desktop, etc.) can interact
# with the knowledge graph over the Model Context Protocol.

petiole main

import "stdlib/cast"
import "stdlib/db"
import "stdlib/json" as jsonpkg
import "stdlib/mcp"
import "stdlib/slice"
import "stdlib/sqliteext"
import "stdlib/string" as strpkg

import "github.com/ncruces/go-sqlite3/ext/spellfix1" as spellfixext
import "github.com/ncruces/go-sqlite3/ext/stats" as statsext
import "github.com/ncruces/go-sqlite3/ext/unicode" as unicodeext
import "github.com/ncruces/go-sqlite3/ext/uuid" as uuidext
import "github.com/ncruces/go-sqlite3/ext/vec1" as vec1ext

# mcpDBPath is the database path used by the MCP server, set from the
# --db flag before starting the server.
var mcpDBPath = ".mizuya/mizuya.db"

# startMCP creates the MCP server, registers all tools, and runs the
# stdio transport (blocking).
func startMCP(dbPath: string) error
    mcpDBPath = dbPath

    router := mcp.NewRouter()
    entityTemplate := "entity://" + "{" + "id}"
    router.AddResource(entityTemplate, func(argName: string, partial: string, prevArgs: map of string to string) list of string
        pool := openDB(mcpDBPath) onerr return empty list of string
        defer db.Close(pool)
        entities := listEntities(pool, "", 500) onerr return empty list of string
        return entities
            |> slice.Filter(e => strpkg.HasPrefix(e.Id, partial))
            |> slice.Map(e => e.Id)
    )

    server := mcp.NewWithCompletion("mizuya", "0.1.0", router.Handler())
    registerTools(server)
    registerResources(server)
    return mcp.Serve(server)

# registerResources exposes knowledge graph data as MCP resources.
# entity://list — snapshot of all entities (name, type, summary).
# entity://{id} — full context for one entity (data + observations + relations).
func registerResources(server: reference mcp.Server)
    mcp.TextResource(
        server,
        "entity://list",
        "Entity list",
        "All knowledge-graph entities",
        listEntitiesResource,
    )
    entityTemplate := "entity://" + "{" + "id}"
    mcp.TextResourceTemplate(
        server,
        entityTemplate,
        "Entity context",
        "Full context: data, observations, and relations for an entity",
        entityContextResource,
    )

func listEntitiesResource(uri: string) (string, error)
    pool := openDB(mcpDBPath) onerr return "", error "{error}"
    defer db.Close(pool)
    entities := listEntities(pool, "", 500) onerr return "", error "{error}"
    data := jsonpkg.PrettyBytes(entities) onerr return "", error "{error}"
    return data as string, empty

func entityContextResource(uri: string) (string, error)
    id := strpkg.TrimPrefix(uri, "entity://")
    if id equals ""
        return "", error "missing entity ID in URI: {uri}"

    pool := openMCPPool() onerr return "", error "{error}"
    defer db.Close(pool)

    e := getEntity(pool, id) onerr return "", error "entity not found: {id}: {error}"
    outgoing := outgoingContext(pool, id) onerr return "", error "{error}"
    incoming := incomingContext(pool, id) onerr return "", error "{error}"
    obs := listObservations(pool, id) onerr return "", error "{error}"

    payload := map of string to any{
        "entity": e,
        "outgoing": outgoing,
        "incoming": incoming,
        "observations": obs,
    }
    data := jsonpkg.PrettyBytes(payload) onerr return "", error "{error}"
    return data as string, empty

# registerTools adds all 6 knowledge graph tools to the MCP server.
func registerTools(server: reference mcp.Server)
    registerUpsertEntity(server)
    registerAddObservation(server)
    registerRelate(server)
    registerSearchTool(server)
    registerGetContext(server)
    registerSimilarTool(server)

# --- Tool: upsert_entity ---

func registerUpsertEntity(server: reference mcp.Server)
    schema := mcp.Schema({
        mcp.Prop("id", "string", "Unique slug, e.g. 'kukicha' or 'vllm-h100-deploy'"),
        mcp.Prop("type", "string", "Entity type: {validEntityTypes}"),
        mcp.Prop("name", "string", "Human-readable name"),
        mcp.Prop("summary", "string", "One-line description"),
        mcp.Prop("tags", "array", "List of string tags"),
    })
        |> mcp.Required({"id", "type", "name"})

    mcp.ToolWithOpts(
        server,
        "upsert_entity",
        "Create or update a knowledge graph entity. Use for projects, tools, people, concepts.",
        schema,
        mcp.ToolOpts{Idempotent: true},
        handleUpsertEntity,
    )

func handleUpsertEntity(args: map of string to any) (any, error)
    id := argString(args, "id")
    etype := argString(args, "type")
    name := argString(args, "name")
    if id equals "" or name equals ""
        return mcp.ErrorResult("id and name are required"), empty

    if etype equals ""
        etype = "concept"

    summary := argString(args, "summary")
    tags := argStringList(args, "tags")

    pool := openMCPPool() onerr return mcp.ErrorResult("cannot open database: {error}"), empty
    defer db.Close(pool)

    upsertEntity(pool, id, etype, name, summary, tags) onerr return mcp.ErrorResult("upsert failed: {error}"), empty

    reEmbed(pool, id) onerr return mcp.ErrorResult("embedding failed: {error}"), empty

    e := getEntity(pool, id) onerr return mcp.ErrorResult("fetch failed: {error}"), empty
    return entityJSON(e), empty

# --- Tool: add_observation ---

func registerAddObservation(server: reference mcp.Server)
    schema := mcp.Schema({
        mcp.Prop("entity_id", "string", "Entity to observe"),
        mcp.Prop("text", "string", "The observation text"),
        mcp.Prop("source", "string", "Source label (default: conversation)"),
    })
        |> mcp.Required({"entity_id", "text"})

    mcp.ToolWithOpts(
        server,
        "add_observation",
        "Record a fact or note about an entity. Appended to the entity's observation history.",
        schema,
        mcp.ToolOpts{Destructive: true},
        handleAddObservation,
    )

func handleAddObservation(args: map of string to any) (any, error)
    id := argString(args, "entity_id")
    text := argString(args, "text")
    if id equals "" or text equals ""
        return mcp.ErrorResult("entity_id and text are required"), empty

    source := argString(args, "source")
    if source equals ""
        source = "conversation"

    pool := openMCPPool() onerr return mcp.ErrorResult("cannot open database: {error}"), empty
    defer db.Close(pool)

    addObservation(pool, id, text, source) onerr return mcp.ErrorResult("observe failed: {error}{suggestionsFor(pool, id)}"), empty

    reEmbed(pool, id) onerr return mcp.ErrorResult("embedding failed: {error}"), empty

    return mcp.TextResult("observed: {text}"), empty

# --- Tool: relate ---

func registerRelate(server: reference mcp.Server)
    schema := mcp.Schema({
        mcp.Prop("src", "string", "Source entity id"),
        mcp.Prop(
            "rel",
            "string",
            "Relation label: uses, depends_on, part_of, related_to, authored_by",
        ),
        mcp.Prop("dst", "string", "Destination entity id"),
    })
        |> mcp.Required({"src", "rel", "dst"})

    mcp.ToolWithOpts(
        server,
        "relate",
        "Create a typed edge between two entities in the knowledge graph.",
        schema,
        mcp.ToolOpts{Idempotent: true},
        handleRelate,
    )

func handleRelate(args: map of string to any) (any, error)
    src := argString(args, "src")
    rel := argString(args, "rel")
    dst := argString(args, "dst")
    if src equals "" or rel equals "" or dst equals ""
        return mcp.ErrorResult("src, rel, and dst are required"), empty

    pool := openMCPPool() onerr return mcp.ErrorResult("cannot open database: {error}"), empty
    defer db.Close(pool)

    relate(pool, src, rel, dst) onerr return mcp.ErrorResult("relate failed: {error}"), empty

    return mcp.TextResult("related: {src} --{rel}--> {dst}"), empty

# --- Tool: search ---

func registerSearchTool(server: reference mcp.Server)
    schema := mcp.Schema({
        mcp.Prop(
            "query",
            "string",
            "Search query (keywords for BM25, also used for semantic similarity in hybrid mode)",
        ),
        mcp.Prop("limit", "integer", "Maximum results (default: 10)"),
    })
        |> mcp.Required({"query"})

    mcp.ToolWithOpts(
        server,
        "search",
        "Search the knowledge graph. Returns entities matching the query using hybrid search (BM25 keyword + cosine vector similarity with RRF merging).",
        schema,
        mcp.ToolOpts{ReadOnly: true},
        handleSearch,
    )

func handleSearch(args: map of string to any) (any, error)
    query := argString(args, "query")
    if query equals ""
        return mcp.ErrorResult("query is required"), empty

    limit := argInt(args, "limit", 10)

    pool := openMCPPool() onerr return mcp.ErrorResult("cannot open database: {error}"), empty
    defer db.Close(pool)

    hits := hybridSearch(pool, query, limit) onerr return mcp.ErrorResult("search failed: {error}"), empty

    data := jsonpkg.PrettyBytes(hits) onerr return mcp.ErrorResult("json error: {error}"), empty
    return mcp.TextResult(data as string), empty

# --- Tool: get_context ---

func registerGetContext(server: reference mcp.Server)
    schema := mcp.Schema({
        mcp.Prop("id", "string", "Entity id to get context for"),
        mcp.Prop(
            "depth",
            "integer",
            "Hops to traverse via the closure vtable (1 = immediate neighbors, default 1)",
        ),
    })
        |> mcp.Required({"id"})

    mcp.ToolWithOpts(
        server,
        "get_context",
        "Get full context for an entity: its data, observations, and related entities up to N hops (default 1).",
        schema,
        mcp.ToolOpts{ReadOnly: true},
        handleGetContext,
    )

func handleGetContext(args: map of string to any) (any, error)
    id := argString(args, "id")
    if id equals ""
        return mcp.ErrorResult("id is required"), empty

    depth := argInt(args, "depth", 1)
    if depth < 1
        depth = 1

    pool := openMCPPool() onerr return mcp.ErrorResult("cannot open database: {error}"), empty
    defer db.Close(pool)

    e := getEntity(pool, id) onerr return mcp.ErrorResult("entity not found: {error}{suggestionsFor(pool, id)}"), empty
    obs := listObservations(pool, id) onerr return mcp.ErrorResult("cannot read observations: {error}"), empty

    if depth > 1
        outReach := reachableOutgoing(pool, id, depth) onerr return mcp.ErrorResult("cannot read outgoing closure: {error}"), empty
        inReach := reachableIncoming(pool, id, depth) onerr return mcp.ErrorResult("cannot read incoming closure: {error}"), empty

        payload := map of string to any{
            "entity": e,
            "depth": depth,
            "outgoing": outReach,
            "incoming": inReach,
            "observations": obs,
        }
        data := jsonpkg.PrettyBytes(payload) onerr return mcp.ErrorResult("json error: {error}"), empty
        return mcp.TextResult(data as string), empty

    outgoing := outgoingContext(pool, id) onerr return mcp.ErrorResult("cannot read outgoing: {error}"), empty
    incoming := incomingContext(pool, id) onerr return mcp.ErrorResult("cannot read incoming: {error}"), empty

    payload := map of string to any{
        "entity": e,
        "outgoing": outgoing,
        "incoming": incoming,
        "observations": obs,
    }

    data := jsonpkg.PrettyBytes(payload) onerr return mcp.ErrorResult("json error: {error}"), empty
    return mcp.TextResult(data as string), empty

# --- Tool: similar ---

func registerSimilarTool(server: reference mcp.Server)
    schema := mcp.Schema({
        mcp.Prop("id", "string", "Use this entity's embedding as the query vector"),
        mcp.Prop("text", "string", "Embed this text and use it as the query vector"),
        mcp.Prop("limit", "integer", "Maximum results (default: 5; ignored when threshold is set)"),
        mcp.Prop(
            "threshold",
            "integer",
            "Return everything in the closest N percentile of distances (1-100). When set, supersedes limit.",
        ),
    })

    mcp.ToolWithOpts(
        server,
        "similar",
        "Vector similarity search. Provide either id (use entity's embedding) or text (embed on the fly). Use threshold for percentile-based cutoff when k is unknown.",
        schema,
        mcp.ToolOpts{ReadOnly: true},
        handleSimilar,
    )

func handleSimilar(args: map of string to any) (any, error)
    id := argString(args, "id")
    text := argString(args, "text")
    if id equals "" and text equals ""
        return mcp.ErrorResult("either id or text is required"), empty

    limit := argInt(args, "limit", 5)
    threshold := argInt(args, "threshold", 0)

    pool := openMCPPool() onerr return mcp.ErrorResult("cannot open database: {error}"), empty
    defer db.Close(pool)

    vec := make(list of float64, 0)
    if id isnt ""
        vec = getEmbedding(pool, id) onerr return mcp.ErrorResult("no embedding for {id}: {error}{suggestionsFor(pool, id)}"), empty
    else
        vec = embedText(text) onerr return mcp.ErrorResult("embed failed: {error}"), empty

    hits := make(list of SimilarHit, 0)
    if threshold > 0
        hits = similarByPercentile(pool, vec, threshold) onerr return mcp.ErrorResult("similarity search failed: {error}"), empty
    else
        hits = similar(pool, vec, limit) onerr return mcp.ErrorResult("similarity search failed: {error}"), empty

    data := jsonpkg.PrettyBytes(hits) onerr return mcp.ErrorResult("json error: {error}"), empty
    return mcp.TextResult(data as string), empty

# --- Helpers ---

# openMCPPool opens the database, registers the SQLite extensions
# referenced at runtime (vec1 for embeddings, uuid for observation
# id defaults), and runs initDB.
func openMCPPool() (db.Pool, error)
    pool := openDB(mcpDBPath) onerr return
    sqliteext.Register(pool, vec1ext.Register) onerr return
    sqliteext.Register(pool, uuidext.Register) onerr return
    sqliteext.Register(pool, statsext.Register) onerr return
    sqliteext.Register(pool, spellfixext.Register) onerr return
    sqliteext.Register(pool, unicodeext.Register) onerr return
    initDB(pool) onerr return
    refreshFuzzyIds(pool) onerr return
    return pool, empty

# reEmbed recomputes and stores the embedding for an entity when its
# corpus has changed since the last pass. The hash short-circuit
# matters most for the openai/ollama providers — repeated upserts of
# the same entity stop turning into network calls.
func reEmbed(pool: db.Pool, id: string) error
    reEmbedIfChanged(pool, id) onerr return
    return empty

# --- Argument helpers ---

# argString extracts a string from the MCP args map.
func argString(args: map of string to any, key: string) string
    v, ok := args[key]
    if not ok
        return ""
    s, err := cast.SmartString(v)
    if err isnt empty
        return ""
    return s

# argInt extracts an int from the MCP args map with a default.
func argInt(args: map of string to any, key: string, defaultVal: int) int
    v, ok := args[key]
    if not ok
        return defaultVal
    n, err := cast.SmartInt(v)
    if err isnt empty
        return defaultVal
    return n

# argStringList extracts a list of strings from the MCP args map.
func argStringList(args: map of string to any, key: string) list of string
    v, ok := args[key]
    if not ok
        return make(list of string, 0)
    v |> switch as arr
        when list of any
            result := make(list of string, 0, len(arr))
            for _, item in arr
                s, err := cast.SmartString(item)
                if err equals empty
                    result = append(result, s)
            return result

    return make(list of string, 0)

# entityJSON marshals an entity for MCP tool results.
func entityJSON(e: Entity) any
    data := jsonpkg.PrettyBytes(e) onerr return mcp.ErrorResult("json error: {error}")
    return mcp.TextResult(data as string)
